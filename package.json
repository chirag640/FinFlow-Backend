{
  "name": "finflow-backend",
  "version": "1.0.0",
  "description": "FinFlow — Your All-in-One Financial OS — REST API",
  "author": "FinFlow",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "stop": "node -e \"const {execSync}=require('child_process');try{const p=execSync('netstat -ano').toString().split('\\n').filter(l=>l.includes(':3000')&&l.includes('LISTENING'))[0];if(p){const pid=p.trim().split(/\\s+/).pop();execSync('taskkill /PID '+pid+' /F');console.log('Killed PID '+pid)}}catch(e){console.log('No process on port 3000')}\"",
    "restart": "npm run stop && npm run start:prod",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:security": "jest --runInBand src/modules/auth/auth.service.spec.ts src/modules/auth/auth.throttle.integration.spec.ts src/modules/auth/auth.session-revoke.integration.spec.ts src/modules/users/users.service.spec.ts src/modules/users/users.pin-lockout.integration.spec.ts src/modules/users/users.delete-account.integration.spec.ts src/modules/expenses/dto/expense-query.dto.spec.ts src/modules/groups/dto/group-expense-query.dto.spec.ts src/modules/expenses/expenses.service.spec.ts src/modules/sync/sync.service.spec.ts src/modules/sync/sync.idempotency-cleanup.integration.spec.ts src/modules/sync/sync.chaos.spec.ts src/modules/sync/dto/sync.dto.spec.ts",
    "test:sync-chaos": "jest --runInBand src/modules/sync/sync.chaos.spec.ts",
    "test:contract": "jest --runInBand src/common/interceptors/transform.interceptor.spec.ts src/modules/sync/sync.service.spec.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:coverage:check": "node ./node_modules/jest/bin/jest.js --coverage --runInBand --coverageReporters=text-summary",
    "loadtest:baseline": "node ./tools/loadtest/http_baseline.mjs",
    "migrate:receipts": "node ./tools/migrations/migrate_receipt_base64_to_storage.mjs",
    "db:seed": "ts-node src/database/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/s3-request-presigner": "^3.888.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^17.3.1",
    "firebase-admin": "^13.6.0",
    "google-auth-library": "^9.6.3",
    "helmet": "^7.1.0",
    "mongodb": "^7.1.0",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.17",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "5.3.3"
  },
  "overrides": {
    "typescript": "5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 16,
        "functions": 15,
        "lines": 18,
        "statements": 18
      }
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
