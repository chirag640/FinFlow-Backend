# ──────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────
# Docker:   mongodb://finflow:YOUR_MONGO_PASSWORD@localhost:27017/finflow_db?authSource=admin
# Local:    mongodb://localhost:27017/finflow_db
DATABASE_URL="mongodb://localhost:27017/finflow_db"

# Credentials for the MongoDB container (used by docker-compose)
MONGO_USER="finflow"
MONGO_PASSWORD="change_me_strong_mongo_password"

# Mongo Express UI credentials (dev only — used by docker-compose)
ME_USERNAME="admin"
ME_PASSWORD="change_me_me_password"

# ──────────────────────────────────────────────────────────────
# JWT  —  generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ──────────────────────────────────────────────────────────────
JWT_SECRET="change_me_64_hex_chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change_me_64_hex_chars_different"
JWT_REFRESH_EXPIRES_IN="7d"

# Optional rotation grace keys (comma-separated) used while phasing out old keys.
# Keep old values here for one token lifetime, then remove them.
JWT_SECRET_PREVIOUS=""
JWT_REFRESH_SECRET_PREVIOUS=""

# API version lifecycle policy (response headers + deprecation signaling)
API_CURRENT_VERSION="v1"
API_SUPPORTED_VERSIONS="v1"
API_DEPRECATED_VERSIONS=""
API_SUNSET_VERSIONS=""
# RFC3339 timestamps; leave empty if not applicable
API_VERSION_DEPRECATION_DATE=""
API_VERSION_SUNSET_DATE=""
# Can be a relative path or full URL
API_LIFECYCLE_POLICY_URL="/api/docs"

# ──────────────────────────────────────────────────────────────
# ENCRYPTION  —  AES-256 field-level encryption for PII (name field)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ──────────────────────────────────────────────────────────────
ENCRYPTION_KEY="change_me_64_hex_chars"

# ──────────────────────────────────────────────────────────────
# GOOGLE OAUTH  (get from console.cloud.google.com)
# ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"

# ──────────────────────────────────────────────────────────────
# EMAIL  (Resend API for OTP / verification emails)
# ──────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
RESEND_API_BASE_URL="https://api.resend.com"
RESEND_REQUEST_TIMEOUT_MS=12000
RESEND_SEND_RETRIES=2
RESEND_RETRY_DELAY_MS=1500
EMAIL_ENFORCE_DELIVERY=true
EMAIL_FROM="FinFlow <onboarding@resend.dev>"
OTP_RESEND_COOLDOWN_SECONDS=60

# ──────────────────────────────────────────────────────────────
# FCM / FIREBASE PUSH NOTIFICATIONS
# Set exactly one of the two service-account options below.
# FIREBASE_SERVICE_ACCOUNT_JSON expects raw JSON (single line).
# FIREBASE_SERVICE_ACCOUNT_BASE64 expects base64-encoded JSON.
# ──────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=""
FIREBASE_SERVICE_ACCOUNT_BASE64=""

# Optional notification tuning
GROUP_LARGE_EXPENSE_APPROVAL_THRESHOLD=5000
GROUP_INACTIVE_MEMBER_DAYS=14

# ──────────────────────────────────────────────────────────────
# RECEIPT STORAGE
# STORAGE_PROVIDER: local | s3
# When using local: RECEIPT_STORAGE_DIR is used for blob persistence.
# When using s3: set bucket/region and optional endpoint/credentials.
# SIGN_READ_URLS=true keeps objects private and serves short-lived signed URLs.
# ──────────────────────────────────────────────────────────────
RECEIPT_STORAGE_PROVIDER="local"
RECEIPT_STORAGE_DIR="storage"
RECEIPT_SIGN_READ_URLS=true
RECEIPT_SIGNED_READ_TTL_SECONDS=900
RECEIPT_PUBLIC_BASE_URL=""
RECEIPT_UPLOAD_SIGNING_SECRET=""

RECEIPT_S3_BUCKET=""
RECEIPT_S3_REGION=""
RECEIPT_S3_ENDPOINT=""
RECEIPT_S3_ACCESS_KEY_ID=""
RECEIPT_S3_SECRET_ACCESS_KEY=""
RECEIPT_S3_KEY_PREFIX="finflow"
RECEIPT_S3_FORCE_PATH_STYLE=false

# ──────────────────────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN="http://localhost:3000,http://localhost:4200"
NODE_ENV="development"
